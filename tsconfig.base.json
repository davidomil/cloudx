{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@cloudx/shared": ["packages/shared/src/index.ts"],
      "@cloudx/plugin-api": ["packages/plugin-api/src/index.ts"]
    }
  }
}
