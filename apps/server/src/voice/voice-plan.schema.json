{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["transcript", "summary", "actions"],
  "properties": {
    "transcript": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "targetTabId", "pluginId", "action", "input", "reason"],
        "properties": {
          "id": { "type": ["string", "null"] },
          "targetTabId": { "type": ["string", "null"] },
          "pluginId": { "type": ["string", "null"] },
          "action": { "type": "string", "minLength": 1 },
          "input": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "submit", "key", "tabId", "title", "relativePath", "content", "oldText", "newText", "create"],
            "properties": {
              "text": { "type": ["string", "null"] },
              "submit": { "type": ["boolean", "null"] },
              "key": { "type": ["string", "null"], "enum": ["enter", "escape", "tab", "ctrl-c", null] },
              "tabId": { "type": ["string", "null"] },
              "title": { "type": ["string", "null"] },
              "relativePath": { "type": ["string", "null"] },
              "content": { "type": ["string", "null"] },
              "oldText": { "type": ["string", "null"] },
              "newText": { "type": ["string", "null"] },
              "create": { "type": ["boolean", "null"] }
            }
          },
          "reason": { "type": ["string", "null"] }
        }
      }
    }
  }
}
