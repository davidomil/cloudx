{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["transcript", "summary", "actions"],
  "properties": {
    "transcript": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "targetTabId", "pluginId", "hookId", "action", "input", "reason"],
        "properties": {
          "id": { "type": ["string", "null"] },
          "targetTabId": { "type": ["string", "null"] },
          "pluginId": { "type": ["string", "null"] },
          "hookId": { "type": ["string", "null"] },
          "action": { "type": "string", "minLength": 1 },
          "input": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "text",
              "submit",
              "key",
              "tabId",
              "title",
              "relativePath",
              "content",
              "oldText",
              "newText",
              "create",
              "url",
              "targetPluginId",
              "cwd",
              "paneId",
              "createDirectory",
              "newPane",
              "splitDirection",
              "pluginId",
              "initialInput",
              "indicator",
              "windowId",
              "context",
              "defaultCwd",
              "sectionId",
              "reason",
              "stopSession"
            ],
            "properties": {
              "text": { "type": ["string", "null"] },
              "submit": { "type": ["boolean", "null"] },
              "key": { "type": ["string", "null"], "enum": ["enter", "escape", "tab", "ctrl-c", null] },
              "tabId": { "type": ["string", "null"] },
              "title": { "type": ["string", "null"] },
              "relativePath": { "type": ["string", "null"] },
              "content": { "type": ["string", "null"] },
              "oldText": { "type": ["string", "null"] },
              "newText": { "type": ["string", "null"] },
              "create": { "type": ["boolean", "null"] },
              "url": { "type": ["string", "null"] },
              "targetPluginId": { "type": ["string", "null"] },
              "cwd": { "type": ["string", "null"] },
              "paneId": { "type": ["string", "null"] },
              "createDirectory": { "type": ["boolean", "null"] },
              "newPane": { "type": ["boolean", "null"] },
              "splitDirection": { "type": ["string", "null"], "enum": ["row", "column", null] },
              "pluginId": { "type": ["string", "null"] },
              "initialInput": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "required": ["url", "resume"],
                "properties": {
                  "url": { "type": ["string", "null"] },
                  "resume": {
                    "type": ["object", "null"],
                    "additionalProperties": false,
                    "required": ["mode", "sessionId", "all", "includeNonInteractive"],
                    "properties": {
                      "mode": { "type": ["string", "null"], "enum": ["picker", "last", "session", null] },
                      "sessionId": { "type": ["string", "null"] },
                      "all": { "type": ["boolean", "null"] },
                      "includeNonInteractive": { "type": ["boolean", "null"] }
                    }
                  }
                }
              },
              "indicator": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "required": ["color", "label", "message"],
                "properties": {
                  "color": { "type": ["string", "null"], "enum": ["green", "yellow", "red", null] },
                  "label": { "type": ["string", "null"] },
                  "message": { "type": ["string", "null"] }
                }
              },
              "windowId": { "type": ["string", "null"] },
              "context": { "type": ["string", "null"] },
              "defaultCwd": { "type": ["string", "null"] },
              "sectionId": { "type": ["string", "null"] },
              "reason": { "type": ["string", "null"] },
              "stopSession": { "type": ["boolean", "null"] }
            }
          },
          "reason": { "type": ["string", "null"] }
        }
      }
    }
  }
}
