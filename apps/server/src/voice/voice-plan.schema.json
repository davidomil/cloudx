{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["transcript", "summary", "actions"],
  "properties": {
    "transcript": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "targetTabId", "pluginId", "action", "input", "reason"],
        "properties": {
          "id": { "type": ["string", "null"] },
          "targetTabId": { "type": ["string", "null"] },
          "pluginId": { "type": ["string", "null"] },
          "action": { "type": "string", "minLength": 1 },
          "input": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "text",
              "submit",
              "key",
              "tabId",
              "title",
              "relativePath",
              "content",
              "oldText",
              "newText",
              "create",
              "url",
              "targetPluginId",
              "cwd",
              "paneId",
              "createDirectory",
              "newPane",
              "splitDirection"
            ],
            "properties": {
              "text": { "type": ["string", "null"] },
              "submit": { "type": ["boolean", "null"] },
              "key": { "type": ["string", "null"], "enum": ["enter", "escape", "tab", "ctrl-c", null] },
              "tabId": { "type": ["string", "null"] },
              "title": { "type": ["string", "null"] },
              "relativePath": { "type": ["string", "null"] },
              "content": { "type": ["string", "null"] },
              "oldText": { "type": ["string", "null"] },
              "newText": { "type": ["string", "null"] },
              "create": { "type": ["boolean", "null"] },
              "url": { "type": ["string", "null"] },
              "targetPluginId": { "type": ["string", "null"] },
              "cwd": { "type": ["string", "null"] },
              "paneId": { "type": ["string", "null"] },
              "createDirectory": { "type": ["boolean", "null"] },
              "newPane": { "type": ["boolean", "null"] },
              "splitDirection": { "type": ["string", "null"], "enum": ["row", "column", null] }
            }
          },
          "reason": { "type": ["string", "null"] }
        }
      }
    }
  }
}
