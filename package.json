{
  "name": "cloudx",
  "private": true,
  "version": "0.1.2",
  "description": "Run and supervise Codex CLI from your phone on your own Linux build machine, with local-first sessions, panes, file tools, diffs, worktrees, and constrained voice control.",
  "keywords": [
    "codex",
    "codex-cli",
    "openai-codex",
    "ai-coding",
    "coding-agent",
    "developer-tools",
    "local-first",
    "self-hosted",
    "mobile-first",
    "web-ui",
    "phone",
    "voice-control",
    "faster-whisper",
    "terminal",
    "tmux",
    "worktrees",
    "typescript",
    "react",
    "fastify",
    "homelab"
  ],
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/plugin-api",
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "cert:create": "node scripts/create-local-cert.mjs",
    "dev": "npm run cert:create && npm run dev -w @cloudx/server",
    "dev:web": "npm run dev -w @cloudx/web",
    "documentation:setup": "python3 -m venv --upgrade-deps services/documentation-indexer/.venv && services/documentation-indexer/.venv/bin/pip install --extra-index-url https://download.pytorch.org/whl/cpu -e \"services/documentation-indexer[dev]\"",
    "documentation:start": "services/documentation-indexer/.venv/bin/cloudx-documentation-indexer",
    "documentation:test": "services/documentation-indexer/.venv/bin/python -m pytest services/documentation-indexer/tests",
    "docs:memory:pdf": "quarto render docs/MEMORY_PLUGIN_GUIDE.qmd --to pdf",
    "docs:screenshots": "npm run build && node scripts/capture-readme-screenshots.mjs",
    "install:wizard": "node scripts/install-cloudx.mjs",
    "service:install": "node scripts/setup-cloudx-whisper-service.mjs",
    "testenv:setup": "node scripts/setup-test-environment.mjs",
    "testenv:start": "npm run build -w @cloudx/web && node scripts/setup-test-environment.mjs --start",
    "testenv:start:lan": "CLOUDX_TEST_HOST=0.0.0.0 npm run testenv:start",
    "testenv:stop": "node scripts/setup-test-environment.mjs --stop",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
